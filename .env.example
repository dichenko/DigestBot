# Telegram Bot API
BOT_TOKEN=your_bot_token_from_botfather

# Telegram MTProto API (https://my.telegram.org/apps)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_USER_SESSION=user_session

# Owner access
OWNER_TELEGRAM_ID=your_telegram_id

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://news_filter_user:${POSTGRES_PASSWORD}@postgres:5432/news_filter_bot
POSTGRES_PASSWORD=your_postgres_password

# LLM
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# Monitor
MONITOR_INTERVAL_MINUTES=5
DEFAULT_SCORE_THRESHOLD=70
TIMEZONE=Europe/Moscow
MAX_POSTS_PER_CHANNEL_PER_RUN=20
MIN_POST_LENGTH=80
MAX_POST_AGE_DAYS=7
ENABLE_DEBUG_SCORING=true
