# Telegram Bot API (создать бота через @BotFather)
BOT_TOKEN=your_bot_token_from_botfather

# Telegram MTProto API (получить на https://my.telegram.org/apps)
# Создай приложение, получи api_id и api_hash
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
# Файл сессии создастся автоматически при первом запуске setup_session.py
TELEGRAM_USER_SESSION=user_session

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# Database (SQLite — просто укажи путь к файлу)
DB_TYPE=sqlite
DB_PATH=data/digest_bot.db
# Для PostgreSQL раскомментируй и заполни:
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=digest_bot
# DB_PASSWORD=your_db_password
# DB_NAME=digest_bot

# Owner access (узнать свой ID: напиши @userinfobot в Telegram)
OWNER_TELEGRAM_ID=your_telegram_id

# Schedule
TIMEZONE=Europe/Moscow
MORNING_DIGEST_TIME=09:00
EVENING_DIGEST_TIME=19:00
